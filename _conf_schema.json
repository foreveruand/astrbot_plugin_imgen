{
    "default_persona": {
        "description": "默认人格",
        "hint": "选择用于 /task 命令和图像生成提示词的人格",
        "type": "string",
        "default": "",
        "_special": "select_persona"
    },
    "default_provider": {
        "description": "默认图像提供商",
        "hint": "选择图像生成提供商: openai, gemini, grok",
        "type": "string",
        "default": "openai",
        "options": ["openai", "gemini", "grok"]
    },
    "default_size": {
        "description": "默认尺寸",
        "hint": "图像尺寸，如: 1024x1024, 1792x1024, 1024x1792",
        "type": "string",
        "default": "1024x1024"
    },
    "session_timeout": {
        "description": "会话超时时间（秒）",
        "hint": "/img 会话的超时时间，默认 300 秒（5分钟）",
        "type": "int",
        "default": 300
    },
    "max_images": {
        "description": "最大图片数量",
        "hint": "单次图生图支持的最大输入图片数量",
        "type": "int",
        "default": 10
    },
    "enable_multi_turn": {
        "description": "启用多轮对话",
        "hint": "启用 /img 多轮对话模式",
        "type": "bool",
        "default": true
    },
    "openai_api_key": {
        "description": "OpenAI API 密钥",
        "hint": "OpenAI 图像生成 API 的密钥",
        "type": "string",
        "default": ""
    },
    "openai_api_url": {
        "description": "OpenAI API 地址",
        "hint": "OpenAI API 基础 URL，如: https://api.openai.com",
        "type": "string",
        "default": "https://api.openai.com"
    },
    "openai_model": {
        "description": "OpenAI 模型",
        "hint": "OpenAI 图像生成模型",
        "type": "string",
        "default": "dall-e-3"
    },
    "openai_quality": {
        "description": "OpenAI 图像质量",
        "hint": "图像质量设置",
        "type": "string",
        "default": "standard",
        "options": ["standard", "hd"]
    },
    "openai_style": {
        "description": "OpenAI 图像风格",
        "hint": "图像风格设置",
        "type": "string",
        "default": "vivid",
        "options": ["vivid", "natural"]
    },
    "gemini_api_key": {
        "description": "Gemini API 密钥",
        "hint": "Google Gemini 图像生成 API 的密钥",
        "type": "string",
        "default": ""
    },
    "gemini_model": {
        "description": "Gemini 模型",
        "hint": "Gemini 图像生成模型",
        "type": "string",
        "default": "imagen-3.0-generate-002"
    },
    "gemini_aspect_ratio": {
        "description": "Gemini 宽高比",
        "hint": "图像宽高比",
        "type": "string",
        "default": "1:1",
        "options": ["1:1", "16:9", "9:16", "4:3", "3:4"]
    },
    "grok_api_key": {
        "description": "Grok API 密钥",
        "hint": "Grok 图像生成 API 的密钥",
        "type": "string",
        "default": ""
    },
    "grok_model": {
        "description": "Grok 模型",
        "hint": "Grok 图像生成模型",
        "type": "string",
        "default": "grok-imagine-1.0"
    },
    "grok_aspect_ratio": {
        "description": "Grok 宽高比",
        "hint": "图像宽高比",
        "type": "string",
        "default": "1:1",
        "options": ["1:1", "16:9", "9:16", "4:3", "3:4"]
    },
    "grok_resolution": {
        "description": "Grok 分辨率",
        "hint": "图像分辨率",
        "type": "string",
        "default": "1024x1024"
    }
}