{
    "general_config": {
        "description": "通用配置",
        "type": "object",
        "items": {
            "default_persona": {
                "description": "默认人格",
                "hint": "选择用于 /task 命令和图像生成提示词的人格",
                "type": "string",
                "default": "",
                "_special": "select_persona"
            },
            "default_provider": {
                "description": "默认图像提供商",
                "hint": "选择图像生成提供商",
                "type": "string",
                "default": "openai",
                "options": ["openai", "gemini", "grok"]
            },
            "default_size": {
                "description": "默认尺寸",
                "hint": "统一的默认尺寸选择。OpenAI 使用像素 size；Gemini/Grok 会映射为对应的宽高比与 1K/2K 分辨率参数。",
                "type": "string",
                "default": "1024x1024",
                "options": [
                    "auto",
                    "1024x1024",
                    "1536x1024",
                    "1024x1536",
                    "2048x2048",
                    "2048x1152",
                    "1152x2048",
                    "3840x2160",
                    "2160x3840"
                ]
            },
            "session_timeout": {
                "description": "会话超时时间（秒）",
                "hint": "/img 会话的超时时间，默认 300 秒（5 分钟）",
                "type": "int",
                "default": 300
            },
            "max_images": {
                "description": "最大图片数量",
                "hint": "单次图生图支持的最大输入图片数量",
                "type": "int",
                "default": 10
            },
            "enable_multi_turn": {
                "description": "启用多轮对话",
                "hint": "启用 /img 多轮对话模式",
                "type": "bool",
                "default": true
            },
            "timeout": {
                "description": "请求超时时间（秒）",
                "hint": "调用图像生成接口的 HTTP 请求超时时间",
                "type": "int",
                "default": 120
            }
        }
    },
    "openai_config": {
        "description": "OpenAI 兼容接口",
        "type": "object",
        "items": {
            "api_key": {
                "description": "API 密钥",
                "hint": "OpenAI 或第三方 OpenAI 兼容图像接口密钥",
                "type": "string",
                "default": ""
            },
            "api_url": {
                "description": "API 基础地址",
                "hint": "例如 https://api.openai.com 或 https://ai.nexahub.one",
                "type": "string",
                "default": "https://api.openai.com"
            },
            "model": {
                "description": "模型",
                "hint": "图像生成模型；使用第三方兼容服务时请填写该服务要求的完整模型名",
                "type": "string",
                "default": "gpt-image-1"
            },
            "use_completions": {
                "description": "使用 Chat Completions 接口",
                "hint": "开启后使用 /v1/chat/completions；关闭后使用 /v1/images/generations 与 /v1/images/edits",
                "type": "bool",
                "default": true
            },
            "quality": {
                "description": "图像质量",
                "hint": "Images API 图像质量。auto 不会发送到严格的第三方接口。",
                "type": "string",
                "default": "auto",
                "options": ["low", "medium", "high", "auto"]
            },
            "background": {
                "description": "图像背景",
                "hint": "透明背景仅 PNG 格式支持。auto 不会发送到严格的第三方接口。",
                "type": "string",
                "default": "auto",
                "options": ["transparent", "opaque", "auto"]
            },
            "output_format": {
                "description": "输出格式",
                "hint": "Images API 输出格式。png 为默认值，不会额外发送。",
                "type": "string",
                "default": "png",
                "options": ["png", "jpeg", "webp"]
            }
        }
    },
    "gemini_config": {
        "description": "Gemini / Imagen",
        "type": "object",
        "items": {
            "api_key": {
                "description": "API 密钥",
                "hint": "Google Gemini 图像生成 API 密钥。启用 Vertex AI 且配置完整时可留空。",
                "type": "string",
                "default": ""
            },
            "model": {
                "description": "模型",
                "hint": "Gemini / Imagen 图像生成模型",
                "type": "string",
                "default": "imagen-3.0-generate-002"
            },
            "vertex_enabled": {
                "description": "启用 Vertex AI",
                "hint": "使用 Google Cloud Vertex AI 而非 Gemini API",
                "type": "bool",
                "default": false
            },
            "vertex_credentials": {
                "description": "Vertex AI 服务账号 JSON 文件",
                "hint": "上传 Google Cloud 服务账号 JSON 凭证文件",
                "type": "file",
                "default": [],
                "file_types": ["json"]
            },
            "vertex_project": {
                "description": "Vertex AI 项目 ID",
                "hint": "Google Cloud 项目 ID",
                "type": "string",
                "default": ""
            },
            "vertex_location": {
                "description": "Vertex AI 区域",
                "hint": "如: us-central1, us-east1, global",
                "type": "string",
                "default": "us-central1"
            }
        }
    },
    "grok_config": {
        "description": "Grok / xAI",
        "type": "object",
        "items": {
            "api_key": {
                "description": "API 密钥",
                "hint": "xAI / Grok 图像生成 API 密钥",
                "type": "string",
                "default": ""
            },
            "model": {
                "description": "模型",
                "hint": "Grok 图像生成模型",
                "type": "string",
                "default": "grok-imagine-image"
            }
        }
    }
}
