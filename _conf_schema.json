{
    "default_persona": {
        "description": "默认人格",
        "hint": "选择用于 /task 命令和图像生成提示词的人格",
        "type": "string",
        "default": "",
        "_special": "select_persona"
    },
    "default_provider": {
        "description": "默认图像提供商",
        "hint": "选择图像生成提供商: openai, gemini, grok",
        "type": "string",
        "default": "openai",
        "options": ["openai", "gemini", "grok"]
    },
    "default_size": {
        "description": "默认尺寸",
        "hint": "图像尺寸，如: 1024x1024, 1792x1024, 1024x1792",
        "type": "string",
        "default": "1024x1024"
    },
    "session_timeout": {
        "description": "会话超时时间（秒）",
        "hint": "/img 会话的超时时间，默认 300 秒（5分钟）",
        "type": "int",
        "default": 300
    },
    "max_images": {
        "description": "最大图片数量",
        "hint": "单次图生图支持的最大输入图片数量",
        "type": "int",
        "default": 10
    },
    "enable_multi_turn": {
        "description": "启用多轮对话",
        "hint": "启用 /img 多轮对话模式",
        "type": "bool",
        "default": true
    },
    "openai_api_key": {
        "description": "OpenAI API 密钥",
        "hint": "OpenAI 图像生成 API 的密钥",
        "type": "string",
        "default": ""
    },
    "openai_api_url": {
        "description": "OpenAI API 地址",
        "hint": "OpenAI API 基础 URL，如: https://api.openai.com；OpenRouter 推荐: https://openrouter.ai/api",
        "type": "string",
        "default": "https://api.openai.com"
    },
    "openai_model": {
        "description": "OpenAI 模型",
        "hint": "OpenAI 图像生成模型（OpenRouter 示例: openai/gpt-5.4-image-2）",
        "type": "string",
        "default": "gpt-image-1"
    },
    "openai_quality": {
        "description": "OpenAI 图像质量",
        "hint": "图像质量设置",
        "type": "string",
        "default": "auto",
        "options": ["low", "medium", "high", "auto"]
    },
    "openai_background": {
        "description": "OpenAI 图像背景",
        "hint": "图像背景设置（透明背景仅 PNG 格式）",
        "type": "string",
        "default": "auto",
        "options": ["transparent", "opaque", "auto"]
    },
    "openai_output_format": {
        "description": "OpenAI 输出格式",
        "hint": "图像输出格式",
        "type": "string",
        "default": "png",
        "options": ["png", "jpeg", "webp"]
    },
    "gemini_api_key": {
        "description": "Gemini API 密钥",
        "hint": "Google Gemini 图像生成 API 的密钥",
        "type": "string",
        "default": ""
    },
    "gemini_model": {
        "description": "Gemini 模型",
        "hint": "Gemini 图像生成模型",
        "type": "string",
        "default": "imagen-3.0-generate-002"
    },
    "gemini_aspect_ratio": {
        "description": "Gemini 宽高比",
        "hint": "图像宽高比",
        "type": "string",
        "default": "1:1",
        "options": ["1:1", "16:9", "9:16", "4:3", "3:4"]
    },
    "gemini_vertex_enabled": {
        "description": "启用 Vertex AI",
        "hint": "使用 Google Cloud Vertex AI 而非 Gemini API",
        "type": "bool",
        "default": false
    },
    "gemini_vertex_credentials": {
        "description": "Vertex AI 服务账号 JSON 文件",
        "hint": "上传 Google Cloud 服务账号 JSON 凭证文件",
        "type": "file",
        "default": [],
        "file_types": ["json"]
    },
    "gemini_vertex_project": {
        "description": "Vertex AI 项目 ID",
        "hint": "Google Cloud 项目 ID",
        "type": "string",
        "default": ""
    },
    "gemini_vertex_location": {
        "description": "Vertex AI 区域",
        "hint": "如: us-central1, us-east1",
        "type": "string",
        "default": "us-central1"
    },
    "grok_api_key": {
        "description": "Grok API 密钥",
        "hint": "xAI / Grok 图像生成 API 的密钥",
        "type": "string",
        "default": ""
    },
    "grok_api_url": {
        "description": "Grok API 地址",
        "hint": "xAI OpenAI 兼容 API 基础 URL，如: https://api.x.ai",
        "type": "string",
        "default": "https://api.x.ai"
    },
    "grok_model": {
        "description": "Grok 模型",
        "hint": "Grok 图像生成模型",
        "type": "string",
        "default": "grok-imagine-image"
    },
    "grok_aspect_ratio": {
        "description": "Grok 默认宽高比",
        "hint": "未显式指定尺寸时的默认宽高比",
        "type": "string",
        "default": "1:1",
        "options": ["1:1", "16:9", "9:16", "4:3", "3:4", "3:2", "2:3", "auto"]
    },
    "grok_resolution": {
        "description": "Grok 输出分辨率",
        "hint": "xAI 图像接口支持的分辨率，推荐 1k 或 2k",
        "type": "string",
        "default": "1k",
        "options": ["1k", "2k"]
    }
}
