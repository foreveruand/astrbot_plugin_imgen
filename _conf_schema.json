{
    "default_persona": {
        "description": "默认人格",
        "hint": "选择用于 /task 命令和图像生成提示词的人格",
        "type": "string",
        "default": "",
        "_special": "select_persona"
    },
    "api_key": {
        "description": "API 密钥",
        "hint": "图像生成 API 的密钥",
        "type": "string",
        "default": ""
    },
    "api_url": {
        "description": "API 地址",
        "hint": "API 基础 URL，如: https://api.openai.com",
        "type": "string",
        "default": "https://api.openai.com"
    },
    "default_provider": {
        "description": "默认图像提供商",
        "hint": "选择图像生成提供商: openai, gemini, grok",
        "type": "string",
        "default": "openai",
        "options": ["openai", "gemini", "grok"]
    },
    "default_model": {
        "description": "默认模型",
        "hint": "图像生成模型名称",
        "type": "string",
        "default": "dall-e-3"
    },
    "default_size": {
        "description": "默认尺寸",
        "hint": "图像尺寸，如: 1024x1024, 1792x1024, 1024x1792",
        "type": "string",
        "default": "1024x1024"
    },
    "timeout": {
        "description": "请求超时时间（秒）",
        "hint": "图像生成请求的超时时间",
        "type": "int",
        "default": 120
    },
    "session_timeout": {
        "description": "会话超时时间（秒）",
        "hint": "/img 会话的超时时间，默认 300 秒（5分钟）",
        "type": "int",
        "default": 300
    },
    "max_images": {
        "description": "最大图片数量",
        "hint": "单次图生图支持的最大输入图片数量",
        "type": "int",
        "default": 10
    },
    "openai_settings": {
        "description": "OpenAI 设置",
        "type": "object",
        "default": {},
        "items": {
            "model": {
                "type": "string",
                "description": "OpenAI 图像模型",
                "default": "dall-e-3"
            },
            "quality": {
                "type": "string",
                "description": "图像质量",
                "default": "standard",
                "options": ["standard", "hd"]
            },
            "style": {
                "type": "string",
                "description": "图像风格",
                "default": "vivid",
                "options": ["vivid", "natural"]
            }
        }
    },
    "gemini_settings": {
        "description": "Gemini 设置",
        "type": "object",
        "default": {},
        "items": {
            "model": {
                "type": "string",
                "description": "Gemini 图像模型",
                "default": "imagen-3.0-generate-002"
            },
            "aspect_ratio": {
                "type": "string",
                "description": "宽高比",
                "default": "1:1",
                "options": ["1:1", "16:9", "9:16", "4:3", "3:4"]
            }
        }
    },
    "grok_settings": {
        "description": "Grok 设置",
        "type": "object",
        "default": {},
        "items": {
            "model": {
                "type": "string",
                "description": "Grok 图像模型",
                "default": "grok-imagine-1.0"
            }
        }
    }
}